{
  "manifest_version": 3,
  "name": "InvoiceIguana",
  "version": "0.1.0",
  "description": "Turn an invoice or receipt into a shareable link — the whole document lives in the URL.",
  "action": { "default_title": "Open InvoiceIguana generator" },
